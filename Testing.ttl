rdfs:label " Distribution Pumping Water Distribution" .

#-----------------Properties ---------------
# This is a template for an Energy Reading. It has no value, only a unit.
energysource:hasEnergyConsumption a owl:ObjectProperty ;
rdfs:domain energysource:EnergySourceProcess ;
rdfs:range qudt:QuantityValue ;
rdfs:label "has Energy Consumption" .
    

energysource:hasElectricalEnergyConsumption a owl:ObjectProperty ;
    rdfs:subPropertyOf energysource:hasEnergyConsumption ;
    rdfs:domain energysource:EnergySourceProcess ;
    rdfs:range qudt:QuantityValue ;
    rdfs:label "has Electrical Energy Consumption" .

energysource:hasThermalEnergyConsumption a owl:ObjectProperty ;
    rdfs:subPropertyOf energysource:hasEnergyConsumption ;
    rdfs:domain energysource:EnergySourceProcess ;
    rdfs:range qudt:QuantityValue ;
    rdfs:label "has Thermal Energy Consumption" .

#-----------Properties of Variables-------------------
# Variables
energysource:hasVariable a owl:ObjectProperty ;
    rdfs:domain energysource:EnergySourceProcess ;
    rdfs:range qudt:QuantityValue .

energysource:hasLiftDistance a owl:ObjectProperty;
rdfs:subPropertyOf energysource:hasVariable.

energysource:hasFlowVolume a owl:ObjectProperty ; 
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasPressureRequirement a owl:ObjectProperty ; 
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasTime a owl:ObjectProperty ; 
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasLengthOfPipeline a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasCrossSectionArea a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasHazenWilliamsCoefficient a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasSlope a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasAge a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasChannelLength a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasConstantSpecificToMaterial a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasSoilPermeability a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasBedSlope a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasFrictionalandVegetativeResistance a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasEvapotranspirationRate a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .

energysource:hasPrecipitationRate a owl:ObjectProperty ;
rdfs:subPropertyOf energysource:hasVariable .


