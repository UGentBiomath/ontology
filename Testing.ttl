#----------------------Restrictions-----------------------------------
energysource:GroundWaterPumping
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasLiftDistance ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION: Must have at least one Flow Volume
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasFlowVolume ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION: Must have at least one Pressure Requirement
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasPressureRequirement ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION: Must have at least one Time variable
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasTime ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] .

    energysource:SurfaceWaterPumping_Normal
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasLengthOfPipeline ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasCrossSectionArea ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasHazenWilliamsCoefficient ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasSlope ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasAge ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] .

    energysource:SurfaceWaterPumping_Gravity
 rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasChannelLength ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasConstantSpecificToMaterial ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasSoilPermeability ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasBedSlope ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasFrictionalandVegetativeResistance ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
      rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasEvapotranspirationRate ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasPrecipitationRate ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] .
