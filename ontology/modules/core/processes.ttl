@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix wf: <https://ugentbiomath.github.io/waterframe#> .

<https://ugentbiomath.github.io/waterframe/modules/core/processes>
    a owl:Ontology ;
    owl:imports <http://purl.obolibrary.org/obo/bfo.owl> ;
    dc:title "waterFRAME: Processes Module" ;
    dc:creator "Jean-David Therrien" ;
    rdfs:comment "BFO-compliant process hierarchy for water treatment. Processes are occurrents (BFO:0000015) that occur in time, distinct from the physical infrastructure (material entities) that enables them." ;
    dc:description "Defines treatment processes as occurrents in accordance with BFO's continuant/occurrent distinction. Physical treatment units (material entities) perform these processes via the wf:performsProcess property." .

# ==============================================================================
# Root Process Class - BFO:0000015 (occurrent)
# ==============================================================================

wf:WaterTreatmentProcess rdfs:subClassOf bfo:BFO_0000015 ;
    rdfs:label "Water treatment process"@en ;
    rdfs:comment "An occurrent process that occurs in water treatment systems. Distinct from the physical infrastructure (material entities) where the process occurs."@en ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000015> .

# ==============================================================================
# Physical Treatment Processes
# ==============================================================================

wf:ScreeningProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Screening process"@en ;
    rdfs:comment "Physical removal of large solids and debris from water through screens or bars. This occurrent process occurs in screening units. Conceptually related to WaWO+ Screening process (unpublished ontology)."@en .

wf:GritRemovalProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Grit removal process"@en ;
    rdfs:comment "Physical settling of heavy inorganic solids (sand, grit) from water. This occurrent process occurs in grit chambers. Conceptually related to WaWO+ GritRemoval process (unpublished ontology)."@en .

wf:PrimaryClarificationProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Primary clarification process"@en ;
    rdfs:comment "Gravity-based settling of suspended solids to form primary sludge. This occurrent process occurs in primary clarifiers. Conceptually related to WaWO+ PrimaryClarification process (unpublished ontology)."@en .

# ==============================================================================
# Biological Treatment Processes
# ==============================================================================

wf:BiologicalOxidationProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Biological oxidation process"@en ;
    rdfs:comment "Aerobic biological process in which microorganisms oxidize organic matter and ammonia. This occurrent process occurs in aeration basins or tanks. Conceptually related to WaWO+ BiologicalOxidation process (unpublished ontology)."@en .

wf:SecondaryClarificationProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Secondary clarification process"@en ;
    rdfs:comment "Gravity-based separation of biological sludge (biomass) from treated water following biological treatment. This occurrent process occurs in secondary clarifiers. Conceptually related to WaWO+ Clarification process (unpublished ontology)."@en .

wf:MembraneFiltrationProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Membrane filtration process"@en ;
    rdfs:comment "Physical separation of solids and microorganisms through semi-permeable membranes (microfiltration, ultrafiltration, nanofiltration, or reverse osmosis). This occurrent process occurs in membrane filter units or membrane bioreactors. Conceptually related to WaWO+ MembraneFiltration process (unpublished ontology)."@en .

# ==============================================================================
# Nutrient Removal Processes
# ==============================================================================

wf:NitrificationProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Nitrification process"@en ;
    rdfs:comment "Aerobic biological oxidation of ammonia (NH4+) to nitrite (NO2-) and then to nitrate (NO3-) by autotrophic bacteria. This occurrent process occurs in nitrification reactors or tanks. Conceptually related to WaWO+ Nitrification process (unpublished ontology)."@en .

wf:DenitrificationProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Denitrification process"@en ;
    rdfs:comment "Anaerobic biological reduction of nitrate (NO3-) to nitrogen gas (N2) under anoxic conditions. This occurrent process occurs in denitrification reactors or tanks. Conceptually related to WaWO+ Denitrification process (unpublished ontology)."@en .

wf:PhosphorusRemovalProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Phosphorus removal process"@en ;
    rdfs:comment "Biological or chemical removal of phosphorus from water. Biological phosphorus removal occurs through luxury uptake by phosphorus-accumulating organisms. Chemical removal uses metal salts for precipitation. This occurrent process occurs in phosphorus removal tanks. Conceptually related to WaWO+ PhosphorusRemoval process (unpublished ontology)."@en .

# ==============================================================================
# Disinfection Process
# ==============================================================================

wf:DisinfectionProcess rdfs:subClassOf wf:WaterTreatmentProcess ;
    rdfs:label "Disinfection process"@en ;
    rdfs:comment "Inactivation or destruction of pathogenic microorganisms through physical (UV radiation) or chemical (chlorination, ozonation) means. This occurrent process occurs in disinfection chambers or units. Conceptually related to WaWO+ Disinfection process (unpublished ontology)."@en .

# ==============================================================================
# Linking Property: Material Entity performs Occurrent Process
# ==============================================================================

wf:performsProcess a owl:ObjectProperty ;
    rdfs:label "performs process"@en ;
    rdfs:comment "Links a physical treatment unit (material entity, BFO:0000040) to the treatment process (occurrent, BFO:0000015) that it performs or enables. This property bridges BFO's fundamental continuant/occurrent distinction."@en ;
    rdfs:domain wf:TreatmentUnit ;
    rdfs:range wf:WaterTreatmentProcess ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000015> ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000040> .
