water:Reading_HydraCAP60_Std a qudt:QuantityValue ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
    rdfs:label "Standard HydraCAP 60 Reading" .

water:Reading_ReverseOsmosis_Std a qudt:QuantityValue ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
