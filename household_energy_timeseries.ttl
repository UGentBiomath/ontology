# =============================================================================
# ONTOLOGY IMPORTS & ALIGNMENT (appended to household_case.ttl)
# =============================================================================
# Make this file self‑contained: import the three domain ontologies.
<https://w3id.org/waterframe/case/household/>
    a owl:Ontology ;
    owl:imports <https://ugentbiomath.github.io/ontology/energy.ttl> ,
                <https://ugentbiomath.github.io/ontology/water_energy.ttl> ,
                <https://ugentbiomath.github.io/ontology/solar_energy.ttl> .

# --- Class assertions ---
case:Membrane_bioreactor a water:MembraneBioReactor .
case:Reverse_osmosis     a water:SeaWaterReverseOsmosis .
case:Electricity_Grid    a solar:GridConnection .
case:Solar_PV_Array      a solar:SolarPVSystem .
case:Household_Electrical_Panel a solar:ElectricalPanel .
case:MBR_AerationBlower  a solar:AerationBlower .
case:RO_HighPressurePump a solar:HighPressurePump .

# --- Link each power‑meter observation to the water process ---
# MBR Power Meter observations → Membrane_bioreactor
[ water:hasElectricalEnergyConsumption [
    a qudt:QuantityValue ;
    qudt:numericValue "0.82"^^xsd:decimal ;
    qudt:unit unit:KiloWatt ;
    qudt:quantityValueDate "2024-01-15T00:00:00"^^xsd:dateTime ;
    energy:isMeasurementType energy:Measured
] ] .
# … repeat for all 24 MBR_Obs_Txx values …
# I will give you a SPARQL pattern to generate this whole block automatically.

# RO Power Meter observations → Reverse_osmosis
# Grid Power Meter observations → Electricity_Grid (use energy:hasEnergyReading)
# Solar Power Meter observations → Solar_PV_Array (use energy:hasEnergyReading)