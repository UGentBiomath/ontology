@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix wf: <https://ugentbiomath.github.io/waterframe#> .

<https://ugentbiomath.github.io/waterframe>
    a owl:Ontology ;
    dc:title "waterFRAME: Modular Water Reuse Ontology" ;
    dc:description "A BFO-grounded modular ontology for household water reuse systems following Alan Rector normalization principles" ;
    dc:creator "Jean-David Therrien" ;
    dc:version "0.1.0" ;
    rdfs:label "waterFRAME"@en ;
    rdfs:comment "A modular ontology for water reuse systems with BFO alignment and support for agent-based optimization queries"@en ;
    owl:versionInfo "0.1.0" ;
    rdfs:seeAlso <https://github.com/UGentBiomath/WaterFRAME> ;

    # Import core modules (currently available)
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/core/material_entities> ;
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/core/processes> ;
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/core/properties> ;

    # Information module - Model metadata 
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/information> ;

    # Capabilities module - Simulation capabilities
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/capabilities> ;

    # Qualities module - Water quality parameters 
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/qualities> ;

    # Sampling module - Sample metadata for regulatory compliance
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/sampling> ;

    # Compliance module - Compliance checking and violation tracking
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/compliance> ;

    # Agents module - Computational agents and operations 
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/agents> ;

    # Scenarios module - Scenario modeling with OWL-Time integration
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/scenarios> ;

    # energy module
    owl:imports <https://ugentbiomath.github.io/waterframe/modules/energy> ;


    # External ontology imports
    owl:imports <http://www.w3.org/2006/time#> ;  # OWL-Time for temporal representation
    owl:imports <http://www.w3.org/ns/prov#> ;  # PROV-O for provenance tracking

    # Future module imports (placeholder for when modules are created)
    # owl:imports <https://ugentbiomath.github.io/waterframe/modules/core/roles> ;

    # Bridge module imports
    owl:imports <https://ugentbiomath.github.io/waterframe/bridges/sosa_alignment> ;
    owl:imports <https://ugentbiomath.github.io/waterframe/bridges/envo_alignment> ;
    # owl:imports <https://ugentbiomath.github.io/waterframe/bridges/prov_alignment> ;
    # owl:imports <https://ugentbiomath.github.io/waterframe/bridges/qudt_alignment> .

    # Module organization annotations
    rdfs:comment "Core modules available: material_entities, processes, properties" ;
    rdfs:comment "Information modules: information, capabilities, qualities, agents, scenarios" ;
    rdfs:comment "Regulatory modules: sampling, compliance" ;
    rdfs:comment "Energy module: Energy balance, consumption, and generation tracking" ;
    rdfs:comment "Bridge modules: SOSA (observations), ENVO (environmental context), QUDT (units)" ;
    rdfs:comment "External ontology imports: OWL-Time (temporal representation), PROV-O (provenance tracking)". 
