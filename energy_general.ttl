@prefix energy:  <https://ugentbiomath.github.io/ontology/energy.ttl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix unit:    <http://qudt.org/vocab/unit/> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .


# =============================================================================
# ONTOLOGY DECLARATION
# =============================================================================

<https://ugentbiomath.github.io/ontology/energy.ttl>
    a owl:Ontology ;
    rdfs:label "Energy Framework Ontology" ;
    rdfs:comment """
        General foundational framework for modelling energy sources, energy demand,
        and energy consumption. This file is domain-agnostic — it defines the core
        concepts and relationships that any domain-specific extension must build upon.

        DESIGN PRINCIPLE:
        The use of an EnergySource creates an EnergyDemand. Satisfying that demand
        results in EnergyConsumption as a measurable by-product. This causal chain
        is the backbone of the framework:

            EnergySource → exploited to meet → EnergyDemand
                                                    └── results in → EnergyConsumption

        DOMAIN EXTENSIONS (import this file and subclass EnergyConsumption):
          - water_energy.ttl : water and wastewater treatment processes
                               <https://ugentbiomath.github.io/ontology/water_energy.ttl>
          - solar_energy.ttl : solar PV systems and household energy components
                               <https://ugentbiomath.github.io/ontology/solar_energy.ttl>

        INSTANCE DATA:
          Domain-specific instance files import the relevant extension ontology and
          use sosa:Observation to record timestamped energy readings. The framework
          supports both directly measured and derived values via energy:isMeasurementType.

        OUT OF SCOPE FOR THIS FILE:
          - Emission intensity and carbon accounting
          - Energy efficiency and conversion losses
          - Domain-specific process classes (defined in extension files)
    """ ;
    rdfs:seeAlso
        <https://ugentbiomath.github.io/ontology/water_energy.ttl> ,
        <https://ugentbiomath.github.io/ontology/solar_energy.ttl> .


# =============================================================================
# TIER 1 — ENERGY SOURCE
# =============================================================================
# An EnergySource is any entity that supplies energy.
# It is the superior class. Everything downstream is a consequence of
# exploiting it. The USE of an EnergySource creates an EnergyDemand,
# which in turn results in EnergyConsumption.

energy:EnergySource a owl:Class ;
    rdfs:label "Energy Source" ;
    rdfs:comment """
        Any natural or processed entity capable of supplying energy to perform work.
        Superior class of the framework. Subclasses represent specific source types
        (renewable, fossil, secondary). Domain extension files introduce source
        individuals (e.g. a rooftop solar PV array, a grid connection) as instances
        of the appropriate subclass.
    """ .

# --- Carrier type (what form the energy takes) ---

# 1. Define the class for energy carriers

energy:EnergyCarrier a owl:Class ;
    rdfs:label "Energy Carrier" ;
    rdfs:comment "The physical form in which energy is stored or delivered." .

# 2. Define the individuals (instances) of that class.

energy:Electrical a energy:EnergyCarrier ; rdfs:label "Electrical" .
energy:Thermal    a energy:EnergyCarrier ; rdfs:label "Thermal" .
energy:Chemical   a energy:EnergyCarrier ; rdfs:label "Chemical" .
energy:Mechanical a energy:EnergyCarrier ; rdfs:label "Mechanical" .


# 3. Define the Object Property pointing to the class
energy:hasEnergyCarrier a owl:ObjectProperty ;
    rdfs:domain energy:EnergySource ;
    rdfs:range energy:EnergyCarrier ;
    rdfs:label "has energy carrier" ;
    rdfs:comment "The physical form in which the source delivers energy: Electrical, Thermal, Chemical, or Mechanical." .

# --- Origin type (primary from nature vs secondary/converted) ---

energy:hasOriginType a owl:DatatypeProperty ;
    rdfs:domain energy:EnergySource ;
    rdfs:range xsd:string ;
    rdfs:label "has origin type" ;
    rdfs:comment "Whether the source is Primary (directly from nature) or Secondary (converted from a primary source)." .

# --- Renewability ---

energy:hasRenewabilityStatus a owl:DatatypeProperty ;
    rdfs:domain energy:EnergySource ;
    rdfs:range xsd:string ;
    rdfs:label "has renewability status" ;
    rdfs:comment "Renewable, Non-renewable, or Partially-renewable." .

# --- Availability profile ---

energy:hasAvailabilityProfile a owl:DatatypeProperty ;
    rdfs:domain energy:EnergySource ;
    rdfs:range xsd:string ;
    rdfs:label "has availability profile" ;
    rdfs:comment "Continuous (always available), Intermittent (weather-dependent), or Dispatchable (controllable on demand)." .

# --- Energy reading (hourly or timestamped supply measurement) ---

energy:hasEnergyReading a owl:ObjectProperty ;
    rdfs:domain energy:EnergySource ;
    rdfs:range qudt:QuantityValue ;
    rdfs:label "has energy reading" ;
    rdfs:comment """
        Links an EnergySource individual to a timestamped supply reading
        (a qudt:QuantityValue carrying a sosa:resultTime and sosa:hasSimpleResult).
        Used by domain extension files to record hourly generation values
        (e.g. solar PV output in kW per hour).
    """ .

# =============================================================================
# TIER 1 SUBCLASSES — What constitutes an EnergySource
# =============================================================================

energy:RenewableEnergySource a owl:Class ;
    rdfs:subClassOf energy:EnergySource ;
    rdfs:label "Renewable Energy Source" ;
    rdfs:comment "An energy source replenished naturally on human timescales. Availability is typically Intermittent or Continuous." .

energy:SolarEnergy a owl:Class ;
    rdfs:subClassOf energy:RenewableEnergySource ;
    rdfs:label "Solar Energy" ;
    rdfs:comment "Energy derived from solar irradiance. Carrier: Electrical (PV) or Thermal (solar thermal)." .

energy:WindEnergy a owl:Class ;
    rdfs:subClassOf energy:RenewableEnergySource ;
    rdfs:label "Wind Energy" ;
    rdfs:comment "Energy derived from wind via turbines. Carrier: Electrical." .

energy:HydroEnergy a owl:Class ;
    rdfs:subClassOf energy:RenewableEnergySource ;
    rdfs:label "Hydro Energy" ;
    rdfs:comment "Energy derived from flowing or falling water. Carrier: Electrical." .

energy:GeothermalEnergy a owl:Class ;
    rdfs:subClassOf energy:RenewableEnergySource ;
    rdfs:label "Geothermal Energy" ;
    rdfs:comment "Energy derived from heat within the earth. Carrier: Thermal or Electrical." .

energy:BiomassEnergy a owl:Class ;
    rdfs:subClassOf energy:RenewableEnergySource ;
    rdfs:label "Biomass Energy" ;
    rdfs:comment "Energy derived from organic matter. Carrier: Chemical or Thermal." .

energy:FossilFuelSource a owl:Class ;
    rdfs:subClassOf energy:EnergySource ;
    rdfs:label "Fossil Fuel Source" ;
    rdfs:comment "Finite carbon-based fuels formed over geological time. Origin: Primary, Non-renewable." .

energy:NaturalGas a owl:Class ;
    rdfs:subClassOf energy:FossilFuelSource ;
    rdfs:label "Natural Gas" ;
    rdfs:comment "Fossil fuel. Carrier: Chemical (combustion) or converted to Thermal/Electrical." .

energy:Diesel a owl:Class ;
    rdfs:subClassOf energy:FossilFuelSource ;
    rdfs:label "Diesel" ;
    rdfs:comment "Fossil fuel. Carrier: Chemical (combustion). Used in generators and engines." .

energy:Coal a owl:Class ;
    rdfs:subClassOf energy:FossilFuelSource ;
    rdfs:label "Coal" ;
    rdfs:comment "Fossil fuel. Carrier: Chemical (combustion) or converted to Electrical." .

energy:SecondaryEnergySource a owl:Class ;
    rdfs:subClassOf energy:EnergySource ;
    rdfs:label "Secondary Energy Source" ;
    rdfs:comment "Energy converted from a primary source and carried to the point of use. Origin: Secondary." .

energy:ElectricityGrid a owl:Class ;
    rdfs:subClassOf energy:SecondaryEnergySource ;
    rdfs:label "Electricity Grid" ;
    rdfs:comment "Public or private electrical distribution network. Carrier: Electrical. Availability: Continuous. Grid power drawn is the balance of total demand minus on-site generation (e.g. solar)." .

energy:ThermalSource a owl:Class ;
    rdfs:subClassOf energy:SecondaryEnergySource ;
    rdfs:label "Thermal Source" ;
    rdfs:comment "Heat energy supplied via district heating or steam networks. Carrier: Thermal." .


# =============================================================================
# TIER 2 — ENERGY DEMAND
# =============================================================================
# EnergyDemand is the causal bridge between EnergySource and EnergyConsumption.
# It is the NEED that justifies drawing from a source.
# Without demand there is no exploitation; without exploitation there is no consumption.
# This class answers the fundamental question: WHY is energy being used at all?

energy:EnergyDemand a owl:Class ;
    rdfs:label "Energy Demand" ;
    rdfs:comment """
        The need that drives the exploitation of an EnergySource. Represents the
        type and magnitude of work required by a process or system. EnergyDemand
        is the causal link — it explains WHY energy is drawn from a source and
        WHY consumption occurs as a result.

        Demand types in the water domain:
          - Mechanical work  (pumping, mixing, aeration)
          - Chemical transformation (dosing, disinfection)
          - Thermal transformation (desalination, heating)
          - Electrochemical (UV, electrolysis)

        Demand types in the solar domain:
          - Electrical supply to treatment equipment
          - Grid balancing (derived: grid draws what solar does not cover)
    """ .

# 2. Define the individuals (instances) of that class belonging to the Standard Demand Types
energy:Mechanical     a energy:DemandType ; rdfs:label "Mechanical" .
energy:Chemical       a energy:DemandType ; rdfs:label "Chemical" .
energy:Thermal        a energy:DemandType ; rdfs:label "Thermal" .
energy:Electrochemical a energy:DemandType ; rdfs:label "Electrochemical" .
energy:GridBalancing  a energy:DemandType ; rdfs:label "Grid Balancing" .

# 3. Define the individuals (instances) of that class belonging to the Standard Demand Frequencies
energy:Continuous a energy:DemandFrequency ; rdfs:label "Continuous" .
energy:Batch      a energy:DemandFrequency ; rdfs:label "Batch" .
energy:Peak       a energy:DemandFrequency ; rdfs:label "Peak" .
energy:hasDemandType a owl:ObjectProperty ;
    rdfs:domain energy:EnergyDemand ;
    rdfs:range energy:DemandType ;
    rdfs:label "has demand type" ;
    rdfs:comment "Type of work the demand represents: Mechanical, Chemical, Thermal, or Electrochemical." .

energy:hasDemandMagnitude a owl:ObjectProperty ;
    rdfs:domain energy:EnergyDemand ;
    rdfs:range qudt:QuantityValue ;
    rdfs:label "has demand magnitude" ;
    rdfs:comment "The quantity of energy required to satisfy the demand (kWh or kW)." .
energy:hasDemandFrequency a owl:ObjectProperty ;
    rdfs:domain energy:EnergyDemand ;
    rdfs:range energy:DemandFrequency ;
    rdfs:label "has demand frequency" ;
    rdfs:comment "Whether the demand is Continuous, Batch, or Peak." .

energy:isMetBy a owl:ObjectProperty ;
    rdfs:domain energy:EnergyDemand ;
    rdfs:range energy:EnergySource ;
    rdfs:label "is met by" ;
    rdfs:comment "Links an EnergyDemand to the EnergySource that supplies it." .

    # =============================================================================
    # TIER 3 — ENERGY CONSUMPTION
    # =============================================================================
    # EnergyConsumption is the measurable by-product of satisfying an EnergyDemand
    # by drawing from an EnergySource. It is not an independent phenomenon —
    # it is caused by demand and traceable back to a source.
    #
    # DOMAIN EXTENSION PATTERN:
    #   To add a new consumption domain, create a new file that:
    #     (1) imports this file via owl:imports
    #     (2) declares a subclass of energy:EnergyConsumption
    #     (3) defines domain-specific process classes and reading individuals
    #
    #   Example:
    #     my_domain:MyEnergyConsumption rdfs:subClassOf energy:EnergyConsumption .

    energy:EnergyConsumption a owl:Class ;
        rdfs:label "Energy Consumption" ;
        rdfs:comment """
            The measurable quantity of energy drawn from an EnergySource to satisfy
            an EnergyDemand. The result of exploitation. Domain-specific consumption
            types are defined as subclasses in extension files:
            - water:WaterEnergyConsumption  (water_energy.ttl)
            - solar:SolarEnergyConsumption  (solar_energy.ttl)
        """ .

        

    # -------------------------------------------------------------------------
    # SMART SUBCLASSES — equivalentClass axioms enable automatic classification
    # -------------------------------------------------------------------------
    energy:ElectricalEnergyConsumption a owl:Class ;
        rdfs:subClassOf energy:EnergyConsumption ;
        owl:equivalentClass [
            rdf:type owl:Class ;
            owl:intersectionOf (
                energy:EnergyConsumption
                [ a owl:Restriction ;
                  owl:onProperty energy:hasEnergyCarrierType ;
                  owl:hasValue energy:Electrical ]
            )
        ] ;
        rdfs:label "Electrical Energy Consumption" ;
        rdfs:comment "Consumption in the form of electricity. Unit: kWh. Automatically classified by a reasoner for any EnergyConsumption individual whose hasEnergyCarrierType is energy:Electrical." .

    energy:ThermalEnergyConsumption a owl:Class ;
        rdfs:subClassOf energy:EnergyConsumption ;
        owl:equivalentClass [
            rdf:type owl:Class ;
            owl:intersectionOf (
                energy:EnergyConsumption
                [ a owl:Restriction ;
                  owl:onProperty energy:hasEnergyCarrierType ;
                  owl:hasValue energy:Thermal ]
            )
        ] ;
        rdfs:label "Thermal Energy Consumption" ;
        rdfs:comment "Consumption in the form of heat. Unit: kWh thermal or MJ. Automatically classified by a reasoner for any EnergyConsumption individual whose hasEnergyCarrierType is energy:Thermal." .

    # --- Properties on EnergyConsumption ---

    energy:hasConsumptionValue a owl:ObjectProperty ;
        rdfs:domain energy:EnergyConsumption ;
        rdfs:range qudt:QuantityValue ;
        rdfs:label "has consumption value" ;
        rdfs:comment "The total energy consumed over a period (kWh or MJ)." .

    energy:hasConsumptionRate a owl:ObjectProperty ;
        rdfs:domain energy:EnergyConsumption ;
        rdfs:range qudt:QuantityValue ;
        rdfs:label "has consumption rate" ;
        rdfs:comment "Energy consumed per unit of output (kWh/m³ for water processes, kW instantaneous for power readings)." .

    # hasEnergyCarrierType is the consumption-side mirror of energy:hasEnergyCarrier
    # on EnergySource. Declared as an ObjectProperty (range: energy:EnergyCarrier)
    # so that owl:equivalentClass restrictions on the subclasses below can reference
    # the same named individuals (energy:Electrical, energy:Thermal, etc.) and
    # a reasoner can perform type inference automatically.
    energy:hasEnergyCarrierType a owl:ObjectProperty ;
        rdfs:domain energy:EnergyConsumption ;
        rdfs:range energy:EnergyCarrier ;
        rdfs:label "has energy carrier type" ;
        rdfs:comment "The carrier form of the consumed energy (same vocabulary as energy:hasEnergyCarrier). Electrical, Thermal, or Chemical." .

    energy:causedByDemand a owl:ObjectProperty ;
        rdfs:domain energy:EnergyConsumption ;
        rdfs:range energy:EnergyDemand ;
        rdfs:label "caused by demand" ;
        rdfs:comment "Inverse of energy:resultsIn. Links consumption back to the demand that caused it." .

    energy:drawnFromSource a owl:ObjectProperty ;
        rdfs:domain energy:EnergyConsumption ;
        rdfs:range energy:EnergySource ;
        rdfs:label "drawn from source" ;
        rdfs:comment "Links a consumption event to the EnergySource it drew from." .

# --- Reading link (for hourly/timestamped instance data) ---

energy:isReadingOf a owl:ObjectProperty ;
    rdfs:label "is reading of" ;
    rdfs:comment """
        Links a qudt:QuantityValue (a timestamped reading individual) back to the
        EnergySource or EnergyConsumption domain individual it measures.
        Used by instance data files (e.g. household_energy_timeseries.ttl) to
        attach sosa:Observation values to the correct ontology individual.
    """ .

# --- Measurement type (measured directly vs derived from inputs) ---
energy:MeasurementType a owl:Class ;
    rdfs:label "Measurement Type" ;
    rdfs:comment """
        Distinguishes how a reading value was obtained:
          'Measured'  — directly observed by a sensor (e.g. Solar_PowerMeter, MBR_PowerMeter)
          'Derived'   — computed from other measured inputs
                        (e.g. Grid power = MBR power + RO power - Solar power;
                              MBR power  = ratedPower x BlowerLoad fraction;
                              RO power   = specificEnergy x FeedFlow)
        SPARQL queries use this flag to decide whether to read a value directly
        or compute it from its inputs.
    """ .
    energy:Measured a owl:MeasurementType ;
    rdfs:label "Measured" ;
    rdfs:comment "A measurement that was directly observed by a sensor." .
    energy:Derived a owl:MeasurementType ;
    rdfs:label "Derived" ;
    rdfs:comment "A measurement that was computed from other measured inputs." .

energy:isMeasurementType a owl:ObjectProperty ;
    rdfs:domain qudt:QuantityValue ;
    rdfs:range energy:MeasurementType ;
    rdfs:label "is measurement type" ;
    rdfs:comment "Indicates whether a reading value was directly measured or derived from other inputs." .

# =============================================================================
# OBSERVABLE PROPERTIES (general — extended by domain files)
# =============================================================================
# Named individuals for sosa:observedProperty links in instance data.
# Domain extension files add further observable property individuals.

energy:ObservableProperty a owl:Class ;
    rdfs:label "Observable Property" ;
    rdfs:comment "A measurable physical quantity observed by a sensor. Open class — domain extension files add further individuals." .

energy:ElectricalPower a owl:NamedIndividual, energy:ObservableProperty ;
    rdfs:label "Electrical Power" ;
    rdfs:comment "Observable property: instantaneous electrical power (kW). Used by PowerMeter sensors." .

energy:LoadFraction a owl:NamedIndividual, energy:ObservableProperty ;
    rdfs:label "Load Fraction" ;
    rdfs:comment "Observable property: dimensionless operating load fraction (0–1). Used by LoadSensor sensors." .
