@prefix energysource:<https://ugentbiomath.github.io/ontology/energy.ttl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix quantity: <http://qudt.org/vocab/quantitykind/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .


# --------------SuperClass -----------------------------------------
energysource:EnergySourceProcess a owl:Class ;
rdfs:label "Energy Source Process " .
#----------------Classes --------------------------------
energysource:WaterConveyance a owl:Class;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label "Water Conveyance".

energysource:WaterTreatment a owl:Class;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label "Water Treatment".

energysource:WaterDistribution a owl:Class ;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label " Water Distribution".

energysource:WasteWaterCollection a owl:Class ;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label " Waste Water Collection".

