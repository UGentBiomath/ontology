@prefix case:         <https://ugentbiomath.github.io/ontology/household_energy_timeseries.ttl#> .
@prefix water:        <https://ugentbiomath.github.io/ontology/water_energy.ttl#> .
@prefix solar:   <https://ugentbiomath.github.io/ontology/solar_energy.ttl#> .
@prefix wf:           <https://ugentbiomath.github.io/waterframe#> .
@prefix energy:       <https://ugentbiomath.github.io/ontology/energy.ttl#> .
@prefix qudt:         <http://qudt.org/schema/qudt/> .
@prefix unit:         <http://qudt.org/vocab/unit/> .
@prefix sosa:         <http://www.w3.org/ns/sosa/> .
@prefix xsd:          <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:         <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix dcterms:      <http://purl.org/dc/terms/> .

case:Electricity_Grid a wf:ExternalAgent, energy:EnergySystemComponent ;
    rdfs:label "Electricity Grid" ;
    rdfs:comment """External electricity grid supplying the household treatment system.
    Modelled as a wf:ExternalAgent so it is substitutable in optimisation scenarios
    (e.g. compare grid-fed vs solar-only vs battery configurations). The grid supplies
    whatever power the on-site solar PV does not cover.""" ;
    wf:hasOutputPort case:Grid_Supply_Out .

# --- Rooftop Solar PV Array ---
case:Solar_PV_Array a energy:SolarPVSystem ;
    rdfs:label "Rooftop Solar PV Array" ;
    rdfs:comment "3 kWp rooftop photovoltaic system. Covers part of the household treatment demand during daylight; surplus is exported to the grid." ;
    wf:hasOutputPort case:Solar_Power_Out .

# --- Household Electrical Panel ---
# Central distribution node that aggregates grid and solar inputs
# and distributes electricity to the treatment units.
case:Household_Electrical_Panel a energy:ElectricalPanel ;
    rdfs:label "Household Electrical Panel" ;
    rdfs:comment "Main distribution board aggregating grid import and solar generation, feeding the MBR and RO treatment units." ;
    wf:hasInputPort  case:HEP_Grid_In ;
    wf:hasInputPort  case:HEP_Solar_In ;
    wf:hasOutputPort case:HEP_MBR_Out ;
    wf:hasOutputPort case:HEP_RO_Out .


# ====================================================================================
# 2.  Electrical Ports and Flow Connections
# ====================================================================================
# All ports carry wf:ElectricalFlow (defined in core/properties.ttl).
# Naming follows the same convention as water ports in household_case1.ttl.

case:Grid_Supply_Out a wf:OutputPort ;
    rdfs:label "Grid Electrical Supply Outlet" ;
    wf:hasFlowType wf:ElectricalFlow ;
    wf:flowsTo case:HEP_Grid_In .

case:Solar_Power_Out a wf:OutputPort ;
    rdfs:label "Solar PV Power Outlet" ;
    wf:hasFlowType wf:ElectricalFlow ;
    wf:flowsTo case:HEP_Solar_In .

case:HEP_Grid_In a wf:InputPort ;
    rdfs:label "Panel Grid Import Inlet" ;
    wf:hasFlowType wf:ElectricalFlow .

case:HEP_Solar_In a wf:InputPort ;
    rdfs:label "Panel Solar Import Inlet" ;
    wf:hasFlowType wf:ElectricalFlow .

case:HEP_MBR_Out a wf:OutputPort ;
    rdfs:label "Panel MBR Supply Outlet" ;
    wf:hasFlowType wf:ElectricalFlow ;
    wf:flowsTo case:MBR_ElectricalIn .

case:HEP_RO_Out a wf:OutputPort ;
    rdfs:label "Panel RO Supply Outlet" ;
    wf:hasFlowType wf:ElectricalFlow ;
    wf:flowsTo case:RO_ElectricalIn .

# Electrical input ports added to existing treatment units
case:MBR_ElectricalIn a wf:InputPort ;
    rdfs:label "MBR Electrical Supply Inlet" ;
    wf:hasFlowType wf:ElectricalFlow .

case:RO_ElectricalIn a wf:InputPort ;
    rdfs:label "RO Electrical Supply Inlet" ;
    wf:hasFlowType wf:ElectricalFlow .

# Attach electrical ports to existing treatment units from household_case1.ttl
case:Membrane_bioreactor wf:hasInputPort case:MBR_ElectricalIn .
case:Reverse_osmosis     wf:hasInputPort case:RO_ElectricalIn .




case:MBR_BlowerRatedPower a qudt:QuantityValue ;
    qudt:numericValue "1.6"^^xsd:decimal ;
    qudt:unit unit:KiloWatt ;
    rdfs:label "MBR Aeration Blower Rated Power (1.6 kW)" .

case:RO_PumpSpecificEnergy a qudt:QuantityValue ;
    qudt:numericValue "3.0"^^xsd:decimal ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
    rdfs:label "RO High-Pressure Pump Specific Energy (3.0 kWh/m³)" .


case:MBR_AerationBlower a energy:AerationBlower ;
    rdfs:label "MBR Aeration Blower" ;
    rdfs:comment """Rotary lobe blower providing air for biological treatment and
    membrane scouring in the MBR. Rated at 1.6 kW; actual draw varies with
    mixed-liquor demand and DO set-point.""" ;
    energy:ratedPower case:MBR_BlowerRatedPower ;
    wf:isSubComponentOf case:Membrane_bioreactor .

case:RO_HighPressurePump a energy:HighPressurePump ;
    rdfs:label "RO High-Pressure Pump" ;
    rdfs:comment """High-pressure feed pump for the reverse osmosis unit. Specific
    energy consumption is 3.0 kWh per m³ of feed water processed. Pump runs
    only when the RO unit is active.""" ;
    energy:specificEnergy case:RO_PumpSpecificEnergy ;
    wf:isSubComponentOf case:Reverse_osmosis .

case:Membrane_bioreactor wf:hasSubComponent case:MBR_AerationBlower .
case:Reverse_osmosis     wf:hasSubComponent case:RO_HighPressurePump .


# ====================================================================================
# 4.  Sensors
# ====================================================================================
# Sensor → port and sensor → component links follow the SOSA alignment pattern
# established in data/ontology/modules/bridges/sosa_alignment.ttl:
#   wf:monitorsPort   (sensor → port it monitors)
#   wf:attachedTo     (sensor → component it is physically attached to)
#   sosa:observes     (sensor → observable property class)

# --- Power meters (direct electrical measurements) ---

case:Grid_PowerMeter a energy:PowerMeter, sosa:Sensor ;
    rdfs:label "Grid Import Power Meter" ;
    rdfs:comment "Measures instantaneous electrical power drawn from the grid. Zero when solar fully covers demand." ;
    sosa:observes    energy:ElectricalPower ;
    wf:monitorsPort  case:Grid_Supply_Out ;
    wf:attachedTo    case:Electricity_Grid .

case:Solar_PowerMeter a energy:PowerMeter, sosa:Sensor ;
    rdfs:label "Solar PV Output Power Meter" ;
    rdfs:comment "Measures instantaneous electrical power produced by the rooftop PV array." ;
    sosa:observes    energy:ElectricalPower ;
    wf:monitorsPort  case:Solar_Power_Out ;
    wf:attachedTo    case:Solar_PV_Array .

case:MBR_PowerMeter a energy:PowerMeter, sosa:Sensor ;
    rdfs:label "MBR Power Meter" ;
    rdfs:comment "Measures total instantaneous power consumed by the MBR unit (blower + ancillaries). Ground-truth for CQ-E3 and Pattern-1 verification." ;
    sosa:observes    energy:ElectricalPower ;
    wf:monitorsPort  case:MBR_ElectricalIn ;
    wf:attachedTo    case:Membrane_bioreactor .

case:RO_PowerMeter a energy:PowerMeter, sosa:Sensor ;
    rdfs:label "RO Power Meter" ;
    rdfs:comment "Measures total instantaneous power consumed by the RO unit (pump + controls). Ground-truth for Pattern-2 verification." ;
    sosa:observes    energy:ElectricalPower ;
    wf:monitorsPort  case:RO_ElectricalIn ;
    wf:attachedTo    case:Reverse_osmosis .

# --- Derivation input sensors ---

case:MBR_BlowerLoad a energy:LoadSensor, sosa:Sensor ;
    rdfs:label "MBR Blower Load Sensor" ;
    rdfs:comment """Measures the operating load fraction of the MBR aeration blower
    (0 = off, 1 = full rated power). Multiply by energy:ratedPower of
    case:MBR_AerationBlower to derive instantaneous power draw (Pattern 1).""" ;
    sosa:observes  energy:LoadFraction ;
    wf:attachedTo  case:MBR_AerationBlower .

case:RO_FeedFlow a wf:FlowSensor, sosa:Sensor ;
    rdfs:label "RO Feed Flow Sensor" ;
    rdfs:comment """Measures volumetric flow rate of water entering the RO unit (m³/h).
    Multiply by energy:specificEnergy of case:RO_HighPressurePump to derive
    instantaneous pump power (Pattern 2).""" ;
    sosa:observes   wf:FlowRate ;
    wf:monitorsPort case:RO_In ;
    wf:attachedTo   case:Reverse_osmosis .


# ====================================================================================
# 5.  Time-Series Observations  —  2024-01-15  (24 hourly readings per sensor)
# ====================================================================================
# All resultTime values are the START of the one-hour interval.
# hasSimpleResult units:
#   Grid_PowerMeter, Solar_PowerMeter, MBR_PowerMeter, RO_PowerMeter : kW (student assigns)
#   MBR_BlowerLoad  : dimensionless fraction (student assigns)
#   RO_FeedFlow     : m³/h (student assigns)
#
# Derivation consistency checks built into the data:
#   MBR power  = MBR_AerationBlower.ratedPower (1.6 kW) × MBR_BlowerLoad value
#   RO power   = RO_HighPressurePump.specificEnergy (3.0 kWh/m³) × RO_FeedFlow value
#   Grid power = MAX(0,  MBR power + RO power − Solar power)


# ── 5a. Grid Import Power Meter ──────────────────────────────────────────────────────

