    qudt:unit unit:KiloWattHourPerCubicMeter ;
    rdfs:label "Standard Primary Clarifiers Reading" .

water:Reading_ActivatedSludge_Std a qudt:QuantityValue ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
