# --------------SuperClass -----------------------------------------
energysource:EnergySourceProcess a owl:Class ;
rdfs:label "Energy Source Process " .
#----------------Classes --------------------------------
energysource:WaterConveyance a owl:Class;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label "Water Conveyance".

energysource:WaterTreatment a owl:Class;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label "Water Treatment".

energysource:WaterDistribution a owl:Class ;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label " Water Distribution".

energysource:WasteWaterCollection a owl:Class ;
rdfs:subClassOf energysource:EnergySourceProcess;
rdfs:label " Waste Water Collection".

