#----------------------Restrictions-----------------------------------
energysource:GroundWaterPumping
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasLiftDistance ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION: Must have at least one Flow Volume
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasFlowVolume ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION: Must have at least one Pressure Requirement
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasPressureRequirement ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION: Must have at least one Time variable
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasTime ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] .
    # RESTRICTION : Must have length of Pipeline
    energysource:SurfaceWaterPumping_Normal
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasLengthOfPipeline ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have Cross Section Area
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasCrossSectionArea ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have Hazen Williams Coefficient
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasHazenWilliamsCoefficient ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have slope
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasSlope ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have Age
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasAge ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] .
    # RESTRICTION : Must have Channel Length
    energysource:SurfaceWaterPumping_Gravity
 rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasChannelLength ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have Constant Specific to Material
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasConstantSpecificToMaterial ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have Soil Permeability
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasSoilPermeability ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRICTION : Must have Bed Slope
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasBedSlope ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRCITION : Must have Frictional and Vegetative Resistance
     rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasFrictionalandVegetativeResistance ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRCITION : Must have Evaporation Transpiration Rate
      rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasEvapotranspirationRate ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] ;
    # RESTRCITION : Must have Precipitation Rate
    rdfs:subClassOf [ 
        a owl:Restriction ; 
        owl:onProperty energysource:hasPrecipitationRate ; 
        owl:someValuesFrom qudt:QuantityValue 
    ] .

#-----------Household case scenario------------------------------
wf:MembraneBioreactorUnit rdfs:subClassOf energysource:MembraneBio_Reactors .

wf:ReverseOsmosisUnit rdfs:subClassOf energysource:RO .

wf:InfiltrationUnit rdfs:subClassOf energysource:WasteWaterDischarge .

# 1. Define the 'Reading Container' (The swap point)
energysource:Reading_MBR_Standard a qudt:QuantityValue ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
    rdfs:label "Standard MBR Reading Container" .

  energysource:Reading_RO_Standard a qudt:QuantityValue ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
    rdfs:label "Standard RO Reading Container" .

    energysource:Reading_Infiltration_Standard a qudt:QuantityValue ;
    qudt:unit unit:KiloWattHourPerCubicMeter ;
    rdfs:label "Standard Infiltration Reading Container" .  

# 2. Logic: Every MBR Instance inherits this container
energysource:MembraneBio_Reactors rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty energysource:hasEnergyConsumption ;
    owl:hasValue energysource:Reading_MBR_Standard
] .

energysource:RO rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty energysource:hasEnergyConsumption ;
    owl:hasValue energysource:Reading_RO_Standard
] .

energysource:WasteWaterDischarge rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty energysource:hasEnergyConsumption ;
    owl:hasValue energysource:Reading_Infiltration_Standard
] .









    
